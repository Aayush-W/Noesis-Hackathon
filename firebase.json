{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "venv",
        ".venv",
        "__pycache__",
        "*.pyc",
        "*.pyo",
        "*.pyd",
        ".env"
      ]
    }
  ],
  "firestore": {
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
