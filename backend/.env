PROJECT_NAME=AskMyNotes
API_V1_STR=/api/v1

# Gemini API Key (get this from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Firebase service account JSON key file path
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Save the downloaded JSON into the backend/ folder and set the path here:
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Security
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
